// Prisma schema — SYS Gate Pass Management System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  credential String   @unique  // phone number or email
  password   String            // bcrypt hash — never store plaintext
  role       String   @default("contractor")  // "contractor" | "admin"
  createdAt  DateTime @default(now())

  records Record[]
}

model Record {
  id        String  @id @default(cuid())
  name      String           // worker full name (Thai)
  idCard    String           // 13-digit Thai national ID, digits only
  company   String
  job       String?          // job title / position
  zone      String?          // work zone e.g. "Zone A", "อาคาร 2"
  startDate String           // ISO date string YYYY-MM-DD
  endDate   String           // ISO date string YYYY-MM-DD
  manDays   Int              // inclusive day count (calcMD result)
  accident  Boolean @default(false)  // admin toggles this after the fact
  createdAt String           // ISO date string YYYY-MM-DD (submission date)
  createdBy String           // User.id of submitting contractor

  author User @relation(fields: [createdBy], references: [id])
}
