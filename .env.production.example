# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to git.

# Prisma — SQLite file path inside the container
DATABASE_URL="file:/app/data/gatepass.db"

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-64-char-random-hex-string"

NODE_ENV="production"
